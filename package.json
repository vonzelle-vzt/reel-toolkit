{
  "name": "@vonzelle-vzt/reel-toolkit",
  "version": "1.6.0",
  "description": "Schema-agnostic video editor primitives shared by NextPlay and FlagPlay.",
  "type": "module",
  "license": "UNLICENSED",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/vonzelle-vzt/reel-toolkit.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js"
    },
    "./clip-window": {
      "types": "./dist/clip-window/index.d.ts",
      "import": "./dist/clip-window/index.js"
    },
    "./logic-version": {
      "types": "./dist/logic-version/index.d.ts",
      "import": "./dist/logic-version/index.js"
    },
    "./network-profile": {
      "types": "./dist/network-profile/index.d.ts",
      "import": "./dist/network-profile/index.js"
    },
    "./tips": {
      "types": "./dist/tips/index.d.ts",
      "import": "./dist/tips/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "release": "node scripts/release.mjs",
    "prepare": "node -e \"process.env.npm_lifecycle_event === 'prepare' && !require('fs').existsSync('dist') && require('child_process').spawnSync('npm', ['run', 'build'], { stdio: 'inherit', shell: true })\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "@mux/mux-player-react": "^3.0.0",
    "lucide-react": ">=0.300.0",
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@mux/mux-player-react": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "@dnd-kit/core": {
      "optional": true
    },
    "@dnd-kit/sortable": {
      "optional": true
    },
    "@dnd-kit/utilities": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mux/mux-player-react": "^3.13.0",
    "@types/react": "^19.0.0",
    "lucide-react": "^0.470.0",
    "react": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
